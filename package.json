{
	"name": "@mauricioroberto/lugo4ts",
	"version": "0.0.25-beta",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"sideEffects": false,
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./gym": {
			"import": "./dist/gym.js",
			"require": "./dist/gym.js",
			"default": "./dist/gym.js"
		},
		"./stress": {
			"import": "./dist/stress.js",
			"require": "./dist/stress.js",
			"default": "./dist/stress.js"
		},
		"./runtime": {
			"import": "./dist/runtime.js",
			"require": "./dist/runtime.js",
			"default": "./dist/runtime.js"
		}
	},
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/mauriciorobertodev/lugo4ts.git"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"build": "rm -rf dist/ && tsc && tsc-alias && rm -rf dist/__tests__",
		"build:watch": "tsc --watch",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"proto:generate": "npx grpc_tools_node_protoc --plugin=protoc-gen-ts=./node_modules/@protobuf-ts/plugin/bin/protoc-gen-ts --ts_out=src/generated --grpc_out=src/generated -I protos protos/*.proto && node scripts/fix-generated-imports.mjs",
		"proto:fix-imports": "node scripts/fix-generated-imports.mjs",
		"format:check": "biome format .",
		"format:fix": "biome format --write .",
		"lint:check": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"keywords": [
		"typescript",
		"lugo bots",
		"lugo4ts",
		"bot"
	],
	"author": "Mauricio Roberto <mauricio.roberto.dev@gmail.com>",
	"license": "MIT",
	"description": "Um pacote para facilitar o desenvolvimento de aplicações Lugo Bots em TypeScript.",
	"dependencies": {
		"@grpc/grpc-js": "^1.13.4",
		"@protobuf-ts/grpc-transport": "^2.11.0",
		"@protobuf-ts/runtime": "^2.11.0",
		"@protobuf-ts/runtime-rpc": "^2.11.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@protobuf-ts/plugin": "^2.11.0",
		"@tensorflow/tfjs-node": "^4.22.0",
		"@types/node": "^22.15.29",
		"@vitest/coverage-v8": "^3.2.3",
		"@vitest/ui": "^3.2.3",
		"grpc-tools": "^1.13.0",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^3.2.3"
	}
}
